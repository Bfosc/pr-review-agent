# AI Provider (default: claude-official)
# AI_PROVIDER=claude-official

# API Key (required)
# AI_API_KEY=sk-ant-xxxxx

# Model name
# AI_MODEL=claude-sonnet-4-20250514

# Custom API Base URL (leave empty to use provider default)
# AI_BASE_URL=

# Max tokens per API call (optional, default: 1000)
# MAX_TOKENS=1000

# API request timeout in ms (optional, default: 60000)
# API_TIMEOUT_MS=60000

# Server port (optional, default: 3000)
# PORT=3000
